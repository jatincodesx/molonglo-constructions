{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/blogs",
      "destination": "/blog",
      "statusCode": 308,
      "regex": "^(?!/_next)/blogs(?:/)?$"
    },
    {
      "source": "/blogs/:slug*",
      "destination": "/blog/:slug*",
      "statusCode": 308,
      "regex": "^(?!/_next)/blogs(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/home-builders-canberra",
      "destination": "/new-home-builders-canberra",
      "statusCode": 308,
      "regex": "^(?!/_next)/home-builders-canberra(?:/)?$"
    },
    {
      "source": "/pages/about.html",
      "destination": "/about",
      "statusCode": 308,
      "regex": "^(?!/_next)/pages/about\\.html(?:/)?$"
    },
