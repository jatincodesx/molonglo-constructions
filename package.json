{
  "name": "molonglo-construction-seo-site",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "preview:cf": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cf": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:link": "npx supabase link --project-ref vloamtiochlgrvouafgm",
    "db:push": "npx supabase db push",
    "db:reset:local": "npx supabase db reset",
    "db:seed": "npx supabase db reset",
    "db:types": "npx supabase gen types typescript --project-id vloamtiochlgrvouafgm --schema public > lib/supabase/database.types.ts",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.4",
    "@supabase/supabase-js": "^2.104.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "gray-matter": "^4.0.3",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "^15.5.15",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.3",
    "eslint": "^9.25.1",
    "eslint-config-next": "^15.5.15",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.85.0"
  }
}
