# Public site
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase server secrets
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Admin production
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
SESSION_SECRET=

# Development only
# ADMIN_PASSWORD is local development only. Never set ADMIN_PASSWORD in Cloudflare production.
ADMIN_PASSWORD=
ADMIN_JWT_SECRET=

# Quote bcrypt hashes in local env files and escape dollar signs:
# ADMIN_PASSWORD_HASH='\$2b\$12\$...'
# In Cloudflare secret value, paste raw hash only:
# $2b$12$...

RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
